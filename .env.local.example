# Copiez ce fichier en ".env.local" et remplissez avec vos propres valeurs.
# NE JAMAIS partager ce fichier ni le mettre sur GitHub.

# Trouvés dans Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique

# Clé secrète Supabase (Project Settings > API > "service_role" secret key)
# Donne un accès complet à la base — utilisée UNIQUEMENT côté serveur (panneau d'administration)
# NE JAMAIS l'exposer au navigateur ni la préfixer par NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role-secrete

# Votre clé API Anthropic (console.anthropic.com > API Keys)
# Utilisée uniquement côté serveur — jamais exposée au navigateur
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
